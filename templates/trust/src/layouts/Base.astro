---
// Base layout — ARIA landmarks (header/nav/main/footer, §6.6), skip link, and the compliance
// footer on every page. All pages render through here.
import '../styles/global.css';
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}
const { title, description, path } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Head title={title} description={description} path={path} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
