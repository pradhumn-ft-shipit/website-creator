---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import PageHeader from '../components/PageHeader.astro';
import { content, presence } from '../config/site.mjs';
// Section-removal guard (§6.3): if this section was not populated the page must not exist.
if (!presence.services) return Astro.redirect('/');
const services = content.services!; // presence guard guarantees defined
---
<Base title="Services" description="How we serve our client families." path="/services">
  <PageHeader eyebrow="How we help" title="Services built around your whole financial life" lede="We provide comprehensive, coordinated advice — not a menu of disconnected products. Every engagement is delivered under a fiduciary standard." />
  <Section>
    <div class="grid gap-14">
      {services.map((s, i) => (
        <article class="grid gap-6 border-b border-brand-navy/10 pb-14 last:border-0 md:grid-cols-[0.35fr_1fr]">
          <div class="flex items-start gap-4">
            <span class="font-serif text-4xl text-brand-goldink">{String(i + 1).padStart(2, '0')}</span>
            <h2 class="mt-1 text-2xl md:text-3xl">{s.title}</h2>
          </div>
          <p class="prose-trust !text-lg">{s.description}</p>
        </article>
      ))}
    </div>
  </Section>
</Base>
