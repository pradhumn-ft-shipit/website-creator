---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import PageHeader from '../components/PageHeader.astro';
import { content, presence } from '../config/site.mjs';
if (!presence.whoWeServe) return Astro.redirect('/');
const whoWeServe = content.whoWeServe!; // presence guard guarantees defined
---
<Base title="Who We Serve" description={whoWeServe.headline} path="/who-we-serve">
  <PageHeader eyebrow="Our clients" title={whoWeServe.headline} lede="We do our best work for a particular kind of family. If you see yourself below, we should talk." />
  <Section>
    <div class="grid gap-10 md:grid-cols-3">
      {whoWeServe.personas.map((p) => (
        <article class="border-t-2 border-brand-gold pt-6">
          <h2 class="text-2xl">{p.title}</h2>
          <p class="mt-4 leading-relaxed text-ink/75">{p.description}</p>
        </article>
      ))}
    </div>
  </Section>
</Base>
