---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import { content, presence } from '../config/site.mjs';

const { firm, home, about } = content;
const services = content.services ?? [];
const hero = home.hero;
const principal = about.principal;
// IMAGE SLOT POLICY (§6.7 hard stop): the hero photo renders ONLY an advisor-uploaded real
// photograph. If none was provided we NEVER synthesize a person — we fall back to a
// typographic credential panel. No AI-generated people, ever.
const heroPhoto = firm.heroPhotoUrl || null;
---

<Base title={undefined} description={hero.subheading} path="/">
  <!-- HERO -->
  <section class="relative overflow-hidden bg-paper">
    <div class="mx-auto grid max-w-6xl items-center gap-14 px-5 py-20 md:grid-cols-[1.15fr_0.85fr] md:px-8 md:py-28">
      <div>
        <p class="eyebrow">{firm.address?.city ? `${firm.address.city}, ${firm.address.region}` : 'Independent · Fiduciary'} &middot; Est. 1974</p>
        <h1 class="mt-6 text-4xl leading-[1.08] md:text-6xl">{hero.heading}</h1>
        <div class="rule-gold mt-8"></div>
        <p class="prose-trust mt-8">{hero.subheading}</p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="/contact" class="btn-primary">{hero.ctaLabel || 'Schedule an introduction'}</a>
          <a href="/about" class="btn-ghost">About the firm</a>
        </div>

        {home.highlights && (
          <dl class="mt-14 grid max-w-lg grid-cols-3 gap-6 border-t border-brand-navy/10 pt-8">
            {home.highlights.map((h) => (
              <div>
                <dt class="text-xs font-semibold uppercase tracking-micro text-brand-gold">{h.label}</dt>
                <dd class="mt-2 font-serif text-2xl text-brand-navy md:text-3xl">{h.value}</dd>
              </div>
            ))}
          </dl>
        )}
      </div>

      <!-- Advisor-photo hero slot (real photo only; typographic fallback otherwise) -->
      <div class="relative">
        {heroPhoto ? (
          <img src={heroPhoto} alt={hero.imageAlt} width="640" height="800" class="w-full rounded-sm object-cover shadow-2xl" loading="eager" />
        ) : (
          <figure class="relative aspect-[4/5] overflow-hidden rounded-sm bg-brand-navy text-paper shadow-2xl">
            <div class="absolute inset-0 opacity-[0.08]" style="background-image:radial-gradient(circle at 1px 1px, #fff 1px, transparent 0);background-size:22px 22px"></div>
            <div class="relative flex h-full flex-col justify-between p-10">
              <span class="font-serif text-6xl leading-none text-brand-gold">{firm.name.split(' ').map((w) => w[0]).slice(0, 2).join('')}</span>
              <div>
                <p class="font-serif text-2xl">{principal?.name}</p>
                <p class="mt-1 text-sm text-paper/70">{principal?.title}</p>
                {principal?.credentials && (
                  <p class="mt-4 flex flex-wrap gap-2">
                    {principal.credentials.map((c) => (
                      <span class="rounded-sm border border-brand-gold/40 px-2 py-1 text-[0.68rem] font-semibold uppercase tracking-wide text-brand-gold">{c}</span>
                    ))}
                  </p>
                )}
              </div>
            </div>
          </figure>
        )}
      </div>
    </div>
  </section>

  <!-- ABOUT PREVIEW -->
  <Section tone="mist" labelledby="about-preview">
    <div class="grid gap-12 md:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">Our firm</p>
        <h2 id="about-preview" class="mt-4 text-3xl md:text-4xl">{about.headline}</h2>
      </div>
      <div class="prose-trust">
        <p>{about.body.split('\n\n')[0]}</p>
        <p class="mt-8"><a href="/about" class="font-sans text-sm font-semibold text-brand-navy underline decoration-brand-gold decoration-2 underline-offset-4">Read our full story &rarr;</a></p>
      </div>
    </div>
  </Section>

  <!-- SERVICES PREVIEW (only if populated — §6.3) -->
  {presence.services && (
    <Section labelledby="services-preview">
      <p class="eyebrow">How we help</p>
      <h2 id="services-preview" class="mt-4 max-w-2xl text-3xl md:text-4xl">Comprehensive counsel, coordinated under one plan</h2>
      <div class="mt-14 grid gap-px overflow-hidden rounded-sm border border-brand-navy/10 bg-brand-navy/10 sm:grid-cols-2 lg:grid-cols-3">
        {services.slice(0, 6).map((s, i) => (
          <div class="bg-paper p-8">
            <span class="font-serif text-lg text-brand-gold">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="mt-3 text-xl">{s.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-ink/70">{s.description}</p>
          </div>
        ))}
      </div>
      <p class="mt-10"><a href="/services" class="btn-ghost">Explore our services</a></p>
    </Section>
  )}

  <!-- CTA -->
  <Section tone="navy" labelledby="home-cta">
    <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
      <h2 id="home-cta" class="max-w-xl text-3xl text-paper md:text-4xl">A relationship built to last decades, not quarters.</h2>
      <a href="/contact" class="shrink-0 rounded-sm bg-brand-gold px-8 py-4 font-sans text-sm font-semibold text-brand-navy transition-opacity hover:opacity-90">Begin a conversation</a>
    </div>
  </Section>
</Base>
