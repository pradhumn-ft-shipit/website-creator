---
// Hygiene 404 (§6.9) — matches the Trust aesthetic, "Back home" link.
import Base from '../layouts/Base.astro';
---
<Base title="Page not found" description="The page you were looking for could not be found." path="/404">
  <section class="mx-auto flex max-w-3xl flex-col items-start px-5 py-32 md:px-8 md:py-44">
    <p class="font-serif text-7xl text-brand-goldink">404</p>
    <h1 class="mt-6 text-4xl md:text-5xl">This page has moved on.</h1>
    <p class="prose-trust mt-6">The page you were looking for isn’t here. Let’s get you back to solid ground.</p>
    <div class="mt-10 flex gap-4">
      <a href="/" class="btn-primary">Back home</a>
      <a href="/contact" class="btn-ghost">Contact us</a>
    </div>
  </section>
</Base>
