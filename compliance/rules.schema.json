{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wri.com/compliance/rules.schema.json",
  "title": "WRI compliance rules.json",
  "description": "Machine-readable compliance ruleset. Authoritative validation is performed by scripts/lint.mjs (`npm run lint:rulesets`); this schema documents the shape and powers editor support.",
  "type": "object",
  "required": ["industry", "version", "status", "prohibited_terms", "required_elements", "required_disclosures", "conditional_rules", "citations"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "industry": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["draft", "published", "retired"] },
    "prohibited_terms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "terms", "severity", "match", "requires_substantiation", "citation"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "terms": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] },
          "match": { "type": "string", "enum": ["literal", "word", "regex"] },
          "requires_substantiation": { "type": "boolean" },
          "citation": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        }
      }
    },
    "prohibited_content": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "severity", "citation"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] },
          "citation": { "type": "string", "minLength": 1 }
        }
      }
    },
    "required_elements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "placement", "citation"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "link_kind": { "type": "string" },
          "placement": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "enum": ["footer", "page", "form", "prominent"] }
          },
          "citation": { "type": "string", "minLength": 1 }
        }
      }
    },
    "required_disclosures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "placement", "citation"],
        "anyOf": [{ "required": ["template"] }, { "required": ["text_pattern"] }],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string" },
          "template": { "type": "string", "minLength": 1 },
          "text_pattern": { "type": "string", "minLength": 1 },
          "placement": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "enum": ["footer", "page", "form", "prominent"] }
          },
          "citation": { "type": "string", "minLength": 1 }
        }
      }
    },
    "conditional_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "when", "citation"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "when": { "type": "object" },
          "requires": { "type": "array", "items": { "type": "string" } },
          "template": { "type": "string" },
          "applies_overlay": { "type": "boolean" },
          "description": { "type": "string" },
          "citation": { "type": "string", "minLength": 1 }
        }
      }
    },
    "citations": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "url": { "type": "string" }
        }
      }
    }
  }
}
